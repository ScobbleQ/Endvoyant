{
  "compilerOptions": {
    "checkJs": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"],
      "#/config": ["./src/config/index.js"],
      "#/logger": ["./src/utils/logger.js"],
      "#/types/*": ["./src/types/*"],
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}

{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"],
      "#/config": ["config.js"],
      "#/logger": ["src/utils/logger.js"]
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "strict": true
  },
  "include": ["src"]
}
